   "source": [
    "EVAL_DATASET = [\n",
    "    ('쿠버네티스 배포 방법', [0, 12]),\n",
    "    ('캐시 관리 전략', [2]),\n",
    "    ('CI/CD 파이프라인 구성', [9, 12]),\n",
    "    ('비동기 웹 서버 프레임워크', [3, 13]),\n",
    "    ('메시지 큐 시스템', [4, 13]),\n",
    "    ('데이터베이스 쿼리 최적화', [5]),\n",
    "    ('인프라 모니터링 도구', [6, 14]),\n",
    "    ('IaC 도구 비교', [7]),\n",
    "    ('컨테이너 이미지 빌드', [1]),\n",
    "    ('서비스 간 통신 프로토콜', [10, 8]),\n",
    "]\n",
    "\n",
    "\n",
    "def hit_rate_at_k(retrieved_indices, relevant_indices, k):\n",
    "    top = retrieved_indices[:k]\n",
    "    return 1.0 if any(r in top for r in relevant_indices) else 0.0\n",
    "\n",
    "\n",
    "def mrr_at_k(retrieved_indices, relevant_indices, k):\n",
    "    top = retrieved_indices[:k]\n",
    "    for i, idx in enumerate(top):\n",
    "        if idx in relevant_indices:\n",
    "            return 1.0 / (i + 1)\n",
    "    return 0.0\n",
    "\n",
    "\n",
    "def evaluate_search_system(search_func, eval_dataset, ks=[1, 3, 5]):\n",
    "    results = {}\n",
    "    for k in ks:\n",
    "        hr_list, mrr_list = [], []\n",
    "        for query, relevant_ids in eval_dataset:\n",
    "            retrieved = search_func(query, k)\n",
    "            hr_list.append(hit_rate_at_k(retrieved, relevant_ids, k))\n",
    "            mrr_list.append(mrr_at_k(retrieved, relevant_ids, k))\n",
    "        results[k] = {'hit_rate': float(np.mean(hr_list)), 'mrr': float(np.mean(mrr_list))}\n",
    "    return results\n",
    "\n",
    "\n",
    "print('=' * 60)\n",
    "print(f\"{'방식':>10} | {'K':>3} | {'Hit Rate':>10} | {'MRR':>10}\")\n",
    "print('-' * 60)\n",
    "for mode in ['bm25', 'vector', 'hybrid']:\n",
    "    search_fn = lambda q, k, m=mode: [idx for idx, _, _ in hybrid_search(q, k, m)]\n",
    "    eval_result = evaluate_search_system(search_fn, EVAL_DATASET)\n",
    "    for k, metrics in eval_result.items():\n",
    "        print(f\"{mode:>10} | {k:>3} | {metrics['hit_rate']:>10.4f} | {metrics['mrr']:>10.4f}\")"
   ]
