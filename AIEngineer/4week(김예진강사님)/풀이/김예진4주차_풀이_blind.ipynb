    "        docs = r['documents'][0]\n",
    "        indices = [int(did.split('_')[1]) for did in r['ids'][0]]\n",
    "        return docs, indices\n",
    "\n",
    "    def generate_answer(self, question, context_docs):\n",
    "        context = '\\n'.join([f'[{i+1}] {d}' for i, d in enumerate(context_docs)])\n",
    "        prompt = f\"\"\"다음 참고 문서만을 기반으로 질문에 답하세요. 참고 문서에 없는 내용은 답하지 마세요.\n",
    "\n",
    "[참고 문서]\n",
    "{context}\n",
    "\n",
    "[질문] {question}\n",
    "\n",
    "[답변]\"\"\"\n",
    "        r = self.openai_client.chat.completions.create(\n",
    "            model='gpt-4o-mini',\n",
    "            messages=[{'role': 'user', 'content': prompt}],\n",
    "            temperature=0, max_tokens=300,\n",
    "        )\n",
    "        return r.choices[0].message.content.strip()\n",
    "\n",
    "    def evaluate_retrieval(self, eval_data, top_k=3):\n",
    "        mrrs = []\n",
    "        for item in eval_data:\n",
    "            _, retrieved_ids = self.retrieve(item['question'], top_k=top_k)\n",
    "            mrr = 0.0\n",
    "            for i, rid in enumerate(retrieved_ids):\n",
    "                if rid in item['relevant_docs']:\n",
    "                    mrr = 1.0 / (i + 1)\n",
    "                    break\n",
    "            mrrs.append(mrr)\n",
    "        return float(np.mean(mrrs))\n",
    "\n",
    "    def evaluate_answer_rouge(self, generated, reference):\n",
    "        return self.scorer.score(reference, generated)['rougeL'].fmeasure\n",
    "\n",
    "    def evaluate_faithfulness(self, question, answer, context_docs):\n",
    "        prompt = f\"\"\"다음 답변이 제공된 참고 문서에만 근거하는지 평가하세요.\n",
    "\n",
    "[참고 문서]\n",
    "{chr(10).join(context_docs)}\n",
    "\n",
    "[답변]\n",
    "{answer}\n",
    "\n",
    "답변의 모든 주장이 참고 문서에 근거하면 faithful=true, 문서에 없는 정보가 포함되면 faithful=false입니다.\n",
    "JSON으로만 응답하세요:\n",
    "{{\"faithful\": true/false, \"score\": 0.0~1.0, \"reason\": \"한줄 설명\"}}\"\"\"\n",
    "        r = self.openai_client.chat.completions.create(\n",
    "            model='gpt-4o-mini',\n",
    "            messages=[{'role': 'user', 'content': prompt}],\n",
    "            temperature=0, max_tokens=200,\n",
    "        )\n",
    "        raw = r.choices[0].message.content\n",
    "        m = re.search(r'\\{.*\\}', raw, re.DOTALL)\n",
    "        try:\n",
    "            return json.loads(m.group(0)) if m else {'faithful': False, 'score': 0.0, 'reason': 'parse_fail'}\n",
    "        except Exception:\n",
    "            return {'faithful': False, 'score': 0.0, 'reason': 'parse_fail'}\n",
    "\n",
    "    def run_full_evaluation(self, eval_data):\n",
    "        results = []\n",
    "        for item in eval_data:\n",
    "            q = item['question']\n",
    "            ref = item['reference']\n",
    "            retrieved_docs, _ = self.retrieve(q, top_k=3)\n",
    "            answer = self.generate_answer(q, retrieved_docs)\n",
    "            rouge = self.evaluate_answer_rouge(answer, ref)\n",
    "            faith = self.evaluate_faithfulness(q, answer, retrieved_docs)\n",
    "            results.append({\n",
    "                'question': q, 'answer': answer, 'rouge_l': rouge,\n",
    "                'faithful': faith.get('faithful'),\n",
    "                'faith_score': faith.get('score', 0.0),\n",
    "            })\n",
    "\n",
    "        mrr = self.evaluate_retrieval(eval_data)\n",
    "        print('=' * 65)\n",
