    "from rank_bm25 import BM25Okapi\n",
    "\n",
    "SEARCH_CORPUS = [\n",
    "    '쿠버네티스 파드는 컨테이너의 최소 배포 단위입니다.',\n",
    "    '도커 이미지는 Dockerfile로부터 레이어 단위로 빌드됩니다.',\n",
