    "        print(f\"  Faithfulness 비율: {sum(1 for r in results if r['faithful']) / len(results):.0%}\")\n",
    "        faith_scores = [r['faith_score'] for r in results if r['faith_score']]\n",
    "        print(f'  평균 Faith Score: {np.mean(faith_scores):.4f}' if faith_scores else '  평균 Faith Score: N/A')\n",
    "        print('-' * 65)\n",
