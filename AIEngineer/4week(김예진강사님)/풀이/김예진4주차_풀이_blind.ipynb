    "# 4주차 VectorDB — 김예진 강사님 풀이 (Blind)\n",
    "- 문제지만 보고 작성. 정답지 미참조.\n",
    "- Q1/Q10은 OpenAI API 키 필요. Q2~Q9는 로컬 SentenceTransformer + ChromaDB + BM25만으로 동작."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# !pip install sentence-transformers openai chromadb rank-bm25 scikit-learn httpx fastapi uvicorn pydantic numpy python-dotenv rouge-score"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, time, re, json, math, asyncio, threading\n",
    "import numpy as np\n",
    "import chromadb\n",
    "from dotenv import load_dotenv\n",
    "from sentence_transformers import SentenceTransformer\n",
    "from openai import OpenAI\n",
    "load_dotenv()\n",
    "print('환경 설정 완료!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Q1. 멀티 모델 임베딩 벤치마크"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "EVAL_PAIRS = [\n",
    "    ('인공지능이 의료 분야를 혁신하고 있다.', 'AI 기술이 병원에서 활용되고 있다.', True),\n",
    "    ('오늘 서울 날씨가 맑습니다.', '서울의 하늘이 화창하고 좋다.', True),\n",
    "    ('주식 시장이 크게 하락했다.', '금융 위기가 발생했다.', True),\n",
    "    ('인공지능이 의료 분야를 혁신하고 있다.', '오늘 저녁에 파스타를 만들 예정이다.', False),\n",
    "    ('서울에서 부산까지 KTX로 2시간 걸린다.', '고양이가 소파에서 낮잠을 자고 있다.', False),\n",
    "    ('딥러닝 모델의 학습률을 조정했다.', '맛있는 김치찌개 레시피를 알려주세요.', False),\n",
    "    ('클라우드 서버 비용이 증가하고 있다.', 'AWS 요금이 올랐다.', True),\n",
    "    ('자연어 처리 기술이 발전하고 있다.', 'NLP 분야에서 새로운 모델이 등장했다.', True),\n",
    "    ('오늘 점심에 비빔밥을 먹었다.', '내일 회의가 오후 3시에 있다.', False),\n",
    "    ('파이썬은 데이터 분석에 널리 사용된다.', 'Python은 ML/AI에서 인기있는 언어이다.', True),\n",
    "]\n",
    "\n",
    "\n",
    "class EmbeddingBenchmark:\n",
    "    def __init__(self):\n",
    "        self.local_model = SentenceTransformer('paraphrase-multilingual-MiniLM-L12-v2')\n",
    "        self.openai_client = OpenAI()\n",
    "\n",
    "    def embed_local(self, texts):\n",
    "        return np.array(self.local_model.encode(texts, normalize_embeddings=False))\n",
    "\n",
    "    def embed_api(self, texts, model='text-embedding-3-small'):\n",
    "        r = self.openai_client.embeddings.create(input=texts, model=model)\n",
    "        return np.array([d.embedding for d in r.data])\n",
    "\n",
    "    def cosine_similarity(self, a, b):\n",
    "        denom = (np.linalg.norm(a) * np.linalg.norm(b))\n",
    "        return float(np.dot(a, b) / denom) if denom else 0.0\n",
    "\n",
    "    def evaluate(self, embed_func, threshold=0.5):\n",
    "        start = time.time()\n",
    "        all_texts = [p[0] for p in EVAL_PAIRS] + [p[1] for p in EVAL_PAIRS]\n",
    "        emb = embed_func(all_texts)\n",
    "        n = len(EVAL_PAIRS)\n",
    "        sims, preds, labels = [], [], []\n",
    "        pos_sims, neg_sims = [], []\n",
    "        for i, (a, b, lbl) in enumerate(EVAL_PAIRS):\n",
    "            s = self.cosine_similarity(emb[i], emb[n + i])\n",
    "            sims.append(s)\n",
    "            preds.append(s >= threshold)\n",
    "            labels.append(lbl)\n",
    "            (pos_sims if lbl else neg_sims).append(s)\n",
    "\n",
    "        correct = sum(int(p == l) for p, l in zip(preds, labels))\n",
    "        tp = sum(1 for p, l in zip(preds, labels) if p and l)\n",
    "        fp = sum(1 for p, l in zip(preds, labels) if p and not l)\n",
    "        fn = sum(1 for p, l in zip(preds, labels) if not p and l)\n",
    "        precision = tp / (tp + fp) if (tp + fp) else 0.0\n",
    "        recall = tp / (tp + fn) if (tp + fn) else 0.0\n",
    "        elapsed = (time.time() - start) * 1000\n",
    "        return {\n",
    "            'accuracy': correct / len(EVAL_PAIRS),\n",
    "            'precision': precision, 'recall': recall,\n",
    "            'avg_sim_positive': float(np.mean(pos_sims)) if pos_sims else 0.0,\n",
    "            'avg_sim_negative': float(np.mean(neg_sims)) if neg_sims else 0.0,\n",
    "            'elapsed_ms': elapsed,\n",
    "        }\n",
    "\n",
    "\n",
    "bench = EmbeddingBenchmark()\n",
    "local_result = bench.evaluate(bench.embed_local)\n",
    "api_result = bench.evaluate(bench.embed_api)\n",
    "\n",
    "print('=' * 65)\n",
    "print(f\"{'지표':>20} | {'오픈소스 (MiniLM)':>16} | {'API (OpenAI)':>16}\")\n",
    "print('-' * 65)\n",
    "for key in ['accuracy', 'precision', 'recall', 'avg_sim_positive', 'avg_sim_negative', 'elapsed_ms']:\n",
    "    lv, av = local_result[key], api_result[key]\n",
    "    fmt = '.1f' if key == 'elapsed_ms' else '.4f'\n",
    "    print(f\"{key:>20} | {lv:>16{fmt}} | {av:>16{fmt}}\")"
   ]
  },
