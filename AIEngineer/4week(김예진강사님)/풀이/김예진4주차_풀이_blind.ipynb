    "    'FastAPI는 async/await 기반의 비동기 웹 프레임워크입니다.',\n",
    "    'Kafka 토픽은 파티션으로 나뉘어 병렬 처리됩니다.',\n",
    "    'PostgreSQL JSONB 타입은 JSON 데이터를 효율적으로 저장합니다.',\n",
    "    'Prometheus AlertManager는 메트릭 임계값 초과 시 알림을 발송합니다.',\n",
    "    'Terraform state 파일은 인프라의 현재 상태를 추적합니다.',\n",
    "    'Nginx 리버스 프록시는 로드 밸런싱과 SSL 종료를 처리합니다.',\n",
    "    'GitHub Actions workflow는 YAML 파일로 CI/CD를 정의합니다.',\n",
    "    'gRPC는 Protocol Buffers를 사용한 고성능 RPC 프레임워크입니다.',\n",
    "    'Elasticsearch는 역인덱스 기반의 풀텍스트 검색 엔진입니다.',\n",
    "    'ArgoCD는 GitOps 방식으로 쿠버네티스 배포를 자동화합니다.',\n",
    "    'Celery는 분산 태스크 큐로 비동기 작업 처리에 사용됩니다.',\n",
    "    'Grafana 대시보드는 다양한 데이터소스의 메트릭을 시각화합니다.',\n",
    "]\n",
    "\n",
    "q5_model = SentenceTransformer('all-MiniLM-L6-v2')\n",
    "tokenized_corpus = [doc.split() for doc in SEARCH_CORPUS]\n",
    "bm25 = BM25Okapi(tokenized_corpus)\n",
    "\n",
    "hybrid_client = chromadb.Client()\n",
    "try:\n",
    "    hybrid_client.delete_collection('hybrid_corpus')\n",
    "except Exception:\n",
    "    pass\n",
    "hybrid_collection = hybrid_client.create_collection('hybrid_corpus', metadata={'hnsw:space': 'cosine'})\n",
    "corpus_emb = q5_model.encode(SEARCH_CORPUS).tolist()\n",
    "hybrid_collection.add(\n",
    "    ids=[f'd_{i}' for i in range(len(SEARCH_CORPUS))],\n",
    "    documents=SEARCH_CORPUS,\n",
    "    embeddings=corpus_emb,\n",
    ")\n",
    "\n",
    "\n",
    "def search_bm25(query, top_k=5):\n",
    "    scores = bm25.get_scores(query.split())\n",
    "    top = sorted(enumerate(scores), key=lambda x: x[1], reverse=True)[:top_k]\n",
    "    return [(i, float(s), SEARCH_CORPUS[i]) for i, s in top]\n",
    "\n",
    "\n",
    "def search_vector(query, top_k=5):\n",
    "    q_emb = q5_model.encode([query]).tolist()\n",
    "    r = hybrid_collection.query(query_embeddings=q_emb, n_results=top_k)\n",
    "    out = []\n",
    "    for did, doc, dist in zip(r['ids'][0], r['documents'][0], r['distances'][0]):\n",
    "        idx = int(did.split('_')[1])\n",
    "        out.append((idx, 1.0 - float(dist), doc))\n",
    "    return out\n",
    "\n",
    "\n",
    "def reciprocal_rank_fusion(bm25_results, vector_results, k=60):\n",
    "    rrf = {}\n",
    "    for rank, (idx, _, doc) in enumerate(bm25_results):\n",
    "        rrf[idx] = rrf.get(idx, 0.0) + 1.0 / (k + rank + 1)\n",
    "    for rank, (idx, _, doc) in enumerate(vector_results):\n",
    "        rrf[idx] = rrf.get(idx, 0.0) + 1.0 / (k + rank + 1)\n",
    "    ranked = sorted(rrf.items(), key=lambda x: x[1], reverse=True)\n",
    "    return [(idx, score, SEARCH_CORPUS[idx]) for idx, score in ranked]\n",
    "\n",
    "\n",
    "def hybrid_search(query, top_k=5, mode='hybrid'):\n",
    "    if mode == 'bm25':\n",
    "        return search_bm25(query, top_k)\n",
    "    if mode == 'vector':\n",
    "        return search_vector(query, top_k)\n",
    "    if mode == 'hybrid':\n",
    "        b = search_bm25(query, top_k * 2)\n",
    "        v = search_vector(query, top_k * 2)\n",
    "        return reciprocal_rank_fusion(b, v)[:top_k]\n",
    "    raise ValueError(mode)\n",
    "\n",
    "\n",
    "query = '컨테이너 배포 자동화'\n",
    "for mode in ['bm25', 'vector', 'hybrid']:\n",
    "    results = hybrid_search(query, top_k=3, mode=mode)\n",
    "    print(f\"\\n[{mode.upper()}] '{query}':\")\n",
    "    for idx, score, doc in results:\n",
    "        print(f'  (score={score:.4f}) {doc[:60]}...')"
