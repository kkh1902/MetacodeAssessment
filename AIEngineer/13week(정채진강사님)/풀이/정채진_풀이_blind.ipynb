    "    # valueFrom (value 아님) — Secrets Manager ARN 참조\n",
    "    secrets = [\n",
    "      {\n",
    "        name      = \"OPENAI_API_KEY\"\n",
    "        valueFrom = data.aws_secretsmanager_secret.openai_api_key.arn\n",
    "      }\n",
    "    ]\n",
    "\n",
    "    logConfiguration = {\n",
