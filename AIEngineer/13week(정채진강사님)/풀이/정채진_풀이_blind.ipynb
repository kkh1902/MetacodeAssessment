   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# (d) 메모리 증가를 위한 Terraform 변경 + 근거\n",
    "# 변경: var.backend_memory default 를 1024 → 2048로 승격 + backend_cpu 1024로 유지(Fargate 유효 조합)\n",
    "# 근거: 유효 Fargate 조합상 1024 CPU는 2048/3072/4096/... MiB와만 매칭. 현 1024 CPU + 1024 MiB는 불가능한 조합이 아니라 \n",
    "# 512 CPU + 1024 MiB 조합이 맞지만, OOM이 반복되므로 CPU도 1 vCPU로 올려 burst 여유를 확보하면서 메모리 2048로 2배 증설.\n",
    "\n",
    "terraform_change = \"\"\"\n",
    "# variables.tf\n",
    "variable \"backend_cpu\" {\n",
    "  type    = number\n",
    "  default = 1024   # 512 → 1024\n",
    "}\n",
    "variable \"backend_memory\" {\n",
    "  type    = number\n",
    "  default = 2048   # 1024 → 2048\n",
    "}\n",
    "\"\"\"\n",
    "print(terraform_change)"
   ]
