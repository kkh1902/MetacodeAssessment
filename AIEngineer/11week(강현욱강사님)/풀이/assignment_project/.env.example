# Google AI Studio API 키 (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# API Key 인증 — generate_api_key() 로 생성한 평문을 hash_api_key()로 해싱한 값
API_KEY_HASH=your-sha256-hash-here

# 인증/Rate Limit 등 미들웨어 동작 모드 (true 시 인증 스킵)
DEV_MODE=true

# Redis 연결 URL (docker-compose 기본값)
REDIS_URL=redis://redis:6379/0

# CORS 허용 오리진 (콤마 구분)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limit 기본값
DEFAULT_RATE_LIMIT=10/minute
CHAT_RATE_LIMIT=5/minute
